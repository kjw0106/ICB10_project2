# ==========================================
# 파이썬 데이터 분석 프로젝트용 .gitignore
# ==========================================

# --- 파이썬 컴파일 및 캐시 파일 ---
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- 가상환경 (Virtual Environments) ---
# uv 및 일반 venv 환경
.venv/
venv/
ENV/
env/
ActiveState.venv

# --- Jupyter Notebook (주피터 노트북) ---
# 노트북 임시 및 체크포인트 파일
.ipynb_checkpoints
*/.ipynb_checkpoints/*
.ipynb_checkpoints/
.ipynb_checkpoints*
# JupyterLab 설정 및 로컬 캐시
.jupyter
.local
# IPykernel 정보
.ipython

# --- 데이터 및 대용량 분석 파일 ---
# 실수로 대용량 데이터셋이 원격 저장소에 커밋되는 것을 방지합니다.
# 프로젝트 내부에서 사용하는 데이터 폴더명을 지정하여 통째로 제외할 수 있습니다.
data/
datasets/
raw_data/
processed_data/
# 일반적인 데이터 포맷 확장자들
*.csv
*.xlsx
*.xls
*.jsonl
*.tsv
*.parquet
*.feather
*.h5
*.hdf5
*.pkl
*.pickle
*.npy
*.npz
*.db
*.sqlite
*.sqlite3

# --- 로그, 캐시 및 분석 결과 리포트 ---
# 분석 과정에서 생성되는 시각화 결과나 로그 파일들
*.log
logs/
figures/
plots/
reports/
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/
.poetry

# --- 환경 변수 및 비밀 정보 ---
.env
.env.shared
.env.secret
.env.*
.secrets

# --- 운영체제 (OS) 및 시스템 툴 ---
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

# --- IDE 설정 (VS Code, PyCharm 등) ---
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# --- 숨김 파일 및 폴더 (Hidden Files & Folders) ---
# 점(.)으로 시작하는 모든 숨김 파일 및 폴더 제외
.*
# .gitignore 파일은 제외하지 않음
!.gitignore

# --- 로컬 설정 및 숨김 리소스 추가 제외 ---
# 스트림릿 비밀 설정 및 로컬 설정 폴더
.streamlit/secrets.toml
.streamlit/

# 프로젝트 압축 및 백업 파일
*.zip
*.tar.gz
*.rar
*.7z

# 에이전트 내부 설정 폴더
.agents/

